{
  "name": "mern",
  "version": "1.0.0",
  "description": "A full-stack MERN React app for users to store and display their entire videogame collections on animated 3D bookshelves.",
  "main": "server.js",
  "scripts": {
    "start": "if-env NODE_ENV=production && npm run start:prod || npm run start:dev",
    "start:prod": "node server.js",
    "start:dev": "concurrently \"nodemon --ignore 'client/*'\" \"npm run client\"",
    "client": "cd client && npm run start",
    "seed": "node scripts/seedDB.js",
    "install": "cd client && npm install",
    "build": "cd client && npm run build",
    "heroku-postbuild": "npm run build"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@ericblade/quagga2": "0.0.2",
    "@fortawesome/fontawesome-svg-core": "^1.2.21",
    "@fortawesome/free-solid-svg-icons": "^5.10.1",
    "@fortawesome/react-fontawesome": "^0.1.4",
    "@types/classnames": "^2.2.9",
    "@types/react-router-dom": "^4.3.4",
    "@types/reactstrap": "^8.0.4",
    "@zendeskgarden/react-forms": "^6.3.1",
    "@zendeskgarden/react-theming": "^6.2.0",
    "axios": "^0.21.4",
    "bcryptjs": "^2.4.3",
    "bootstrap": "^4.3.1",
    "connect-mongo": "^5.1.0",
    "dotenv": "^8.1.0",
    "express": "^4.17.1",
    "express-session": "^1.16.2",
    "if-env": "^1.0.4",
    "mdbreact": "^4.19.0",
    "mongoose": "^7.8.9",
    "mongoose-unique-validator": "^4.0.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "react-bootstrap": "^1.0.0-beta.11",
    "react-dom": "^16.9.0",
    "react-router-dom": "^5.0.1",
    "react-share": "^3.0.1",
    "reactstrap": "^8.0.1",
    "styled-components": "^4.4.1"
  }
}
